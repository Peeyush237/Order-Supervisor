# ---- Copy to backend/.env (or export) before running the backend ----

# --- Application database (matches docker-compose app-postgres) ---
DATABASE_URL=postgresql+asyncpg://supervisor:supervisor@localhost:5432/order_supervisor

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-supervisor

# --- LLM (provider-pluggable; default Groq) ---
# LLM_PROVIDER: groq | openai | anthropic | mock
# Use "mock" to run the whole system end-to-end with no API key (deterministic stub agent).
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# --- Demo time scaling ---
# real_sleep_seconds = sim_seconds * TIME_SCALE / 3600.
# TIME_SCALE = "real seconds per simulated hour". 1 => a "6-hour" sleep is ~6s.
# Keep small so sleep->wake is visible in a demo/video.
TIME_SCALE=1

# --- Frontend ---
# (set in frontend/.env.local) NEXT_PUBLIC_API_BASE=http://localhost:8000
